instinct greet(name) {
    stash clean_name = play single_space(name);

    sniff clean_name == "" {
        bring "hello, mysterious night friend";
    } else {
        bring "hello, ${clean_name}";
    }
}

scrounge "what name should I sniff for? " -> name;
stash message = play greet(name);
hiss message;
